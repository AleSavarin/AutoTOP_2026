<Window x:Class="Autotop.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autotop V2 (Simulación)" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Conectar todo" Command="{Binding ConnectAllCommand}" Width="100" Margin="5"/>
            <Button Content="Iniciar Macro" Command="{Binding StartMacroCommand}" Width="100" Margin="5"/>
            <Button Content="Detener" Command="{Binding StopCommand}" Width="100" Margin="5"/>
            <CheckBox Content="Registro continuo" IsChecked="{Binding ContinuousLogging}" Margin="10,0"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Referencia (mV/V): " FontWeight="Bold"/>
            <TextBlock Text="{Binding ReferenceMvV, StringFormat={}{0:F6}}" Width="100"/>
            <TextBlock Text="  Incógnita (mV/V): " FontWeight="Bold" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding DutMvV, StringFormat={}{0:F6}}" Width="100"/>
            <TextBlock Text="  Estabilidad (ppm): " FontWeight="Bold" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding StabilityPpm}" Width="80"/>
            <TextBlock Text="  Estado: " FontWeight="Bold" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding StatusText}" Width="150"/>
        </WrapPanel>

        <ListView Grid.Row="2" ItemsSource="{Binding LogEntries}" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Background="Black" Foreground="LightGreen">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}" 
                               Foreground="{Binding ColorBrush}"
                               FontFamily="Consolas" FontSize="11"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>